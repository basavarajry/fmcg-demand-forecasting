# Application
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
API_ACCESS_TOKEN=your-bearer-token-here

# Paths
DATA_DIR=./data
MODEL_DIR=./models
MLFLOW_TRACKING_URI=./mlruns

# Training
CUDA_VISIBLE_DEVICES=0
MAX_EPOCHS=50
BATCH_SIZE=64
LEARNING_RATE=0.001
FORECAST_HORIZON=28
ENCODER_LENGTH=90
WMAPE_RETRAIN_THRESHOLD=0.25

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=fmcg-forecast-models
S3_DATA_PREFIX=data/
S3_MODEL_PREFIX=models/

# Kaggle (for dataset download)
KAGGLE_USERNAME=
KAGGLE_KEY=

# MLflow
MLFLOW_EXPERIMENT_NAME=fmcg-demand-forecasting

# Monitoring
EVIDENTLY_REPORT_DIR=./reports/evidently
DRIFT_THRESHOLD=0.1
